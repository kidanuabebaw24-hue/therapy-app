PORT=5000
NEON_DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<database>?sslmode=require
JWT_SECRET=replace-with-a-strong-secret
GROQ_API_KEY=replace-with-your-groq-key
NODE_ENV=development

# Chapa Payment Gateway Sandbox Keys
CHAPA_PUBLIC_KEY=replace-with-public-key
CHAPA_SECRET_KEY=replace-with-secret-key
CHAPA_ENCRYPTION_KEY=replace-with-encryption-key
